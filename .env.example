# Copy this file to .env and fill in the values
# cp .env.example .env

# Rails master key (config/master.key の内容)
RAILS_MASTER_KEY=

# Database password (開発環境はtrust認証のため空でOK)
DB_PASSWORD=

# Internal API key shared by Dugout and trusted sibling services.
# Production must use a strong random value; never use the development fallback.
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=
