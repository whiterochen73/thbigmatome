# THBIG Dugout 本番環境設定テンプレート
# このファイルを .env.production にコピーして、プレースホルダーを実際の値に置き換えること。
# .env.production は git にコミットしない（.gitignore に追加済みであること）

# ----------------------------------------------------------------
# データベース
# ----------------------------------------------------------------
# PostgreSQL パスワード（推測困難な長いランダム文字列を設定すること）
DB_PASSWORD=CHANGE_ME_strong_random_password

# ----------------------------------------------------------------
# Rails
# ----------------------------------------------------------------
# config/master.key の内容をそのままペーストする
RAILS_MASTER_KEY=CHANGE_ME_from_config_master_key

# ----------------------------------------------------------------
# アプリケーション
# ----------------------------------------------------------------
# 初期管理者パスワード（初回 seed 時に使用）
INITIAL_PASSWORD=CHANGE_ME_initial_admin_password

# アプリのドメイン名
DOMAIN_NAME=dugout.thbig.fun

# アプリのホスト名またはIPアドレス（メール送信等で使用）
APP_HOST=dugout.thbig.fun

# ----------------------------------------------------------------
# CORS（フロントエンドのオリジン）
# ----------------------------------------------------------------
# フロントエンドのアクセス元を指定
CORS_ALLOWED_ORIGIN=https://dugout.thbig.fun

# ----------------------------------------------------------------
# フロントエンド（Vue.js ビルド時に埋め込まれる）
# ----------------------------------------------------------------
# Rails API のベース URL（フロントエンドから見たアドレス）
# Nginx が /api/ を rails コンテナに中継するため、フロントエンドのオリジンを指定
VITE_API_BASE_URL=https://dugout.thbig.fun/api/v1
