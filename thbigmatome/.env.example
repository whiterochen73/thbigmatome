# thbigmatome バックエンド 環境変数サンプル
# このファイルをコピーして .env を作成し、適切な値を設定すること。
# .env はgitignore済みのため、実際の値をコミットしないこと。

# データベース接続
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
# DB_HOST=db         # Docker Compose利用時: サービス名 "db"
# DB_PORT=5432       # デフォルト: 5432

# Railsマスターキー（config/credentials.yml.enc の復号に使用）
RAILS_MASTER_KEY=your_master_key_here

# 本番DBパスワード（database.yml の production セクション用）
THBIGMATOME_DATABASE_PASSWORD=your_production_db_password

# CORS許可オリジン（カンマ区切りで複数指定可）
# 開発: http://localhost:5173
# 本番: https://your-production-domain.com
CORS_ALLOWED_ORIGIN=http://localhost:5173

# 本番ホスト名（メールURLオプション等で使用）
# APP_HOST=your-production-domain.com

# ログレベル（debug/info/warn/error）
# RAILS_LOG_LEVEL=info

# パーサーAPIのURL（Pythonパーサーサービス）
THBIG_IRC_PARSER_PYTHON=/path/to/thbig-irc-parser/.venv/bin/python

# 本番用コミッショナー初期パスワード（db:seed 時に使用）
# 必ず十分に強いパスワードを設定すること
INITIAL_PASSWORD=your_initial_password_here
