# Development Dockerfile for thbigmatome-front (Vue.js)
# Node.js 20 with Vite hot-reload support
FROM node:20-alpine

WORKDIR /app

# Install dependencies (cached layer)
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile

# Copy application code (bind mount in development)
COPY . .

EXPOSE 5173

CMD ["yarn", "dev", "--", "--host", "0.0.0.0"]
